{
  "strategies": {
    "VWAP_Breakout": {
      "class": "VWAPBreakoutStrategy",
      "module": "src.strategies.VWAP_Breakout",
      "priority": 1,
      "enabled": true,
      "market_conditions": ["trending", "volatile"],
      "parameters": {
        "stop_loss": 0.03,
        "take_profit": 0.15,
        "sma_short": 10,
        "sma_long": 30,
        "volume_threshold": 1.2,
        "confirmation_bars": 1,
        "breakout_min_percent": 0.003,
        "trailing_stop": 0.05,
        "trailing_start_threshold": 0.03,
        "max_holding_period": 10
      },
      "risk_profile": {
        "volatility_tolerance": "high",
        "max_position_size": 0.15,
        "preferred_market_cap": "large_cap"
      },
      "performance_weights": {
        "return_weight": 0.4,
        "risk_weight": 0.3,
        "consistency_weight": 0.3
      }
    },
    "GoldenCross": {
      "class": "GCStrategy", 
      "module": "src.strategies.gc_strategy_signal",
      "priority": 2,
      "enabled": true,
      "market_conditions": ["trending", "bullish"],
      "parameters": {
        "short_window": 50,
        "long_window": 200,
        "confirmation_period": 3,
        "volume_confirmation": true,
        "trend_strength_threshold": 0.1
      },
      "risk_profile": {
        "volatility_tolerance": "medium",
        "max_position_size": 0.20,
        "preferred_market_cap": "all"
      },
      "performance_weights": {
        "return_weight": 0.5,
        "risk_weight": 0.2,
        "consistency_weight": 0.3
      }
    },
    "Momentum": {
      "class": "MomentumInvestingStrategy",
      "module": "src.strategies.Momentum_Investing",
      "priority": 3,
      "enabled": true,
      "market_conditions": ["trending", "strong_volume"],
      "parameters": {
        "lookback_period": 12,
        "momentum_threshold": 0.05,
        "volume_multiplier": 1.5,
        "relative_strength_period": 6,
        "rebalance_frequency": "monthly"
      },
      "risk_profile": {
        "volatility_tolerance": "high",
        "max_position_size": 0.12,
        "preferred_market_cap": "mid_to_large_cap"
      },
      "performance_weights": {
        "return_weight": 0.6,
        "risk_weight": 0.2,
        "consistency_weight": 0.2
      }
    },
    "VWAP_Bounce": {
      "class": "VWAPBounceStrategy",
      "module": "src.strategies.VWAP_Bounce",
      "priority": 4,
      "enabled": true,
      "market_conditions": ["sideways", "support_resistance"],
      "parameters": {
        "bounce_threshold": 0.02,
        "volume_confirmation": true,
        "support_resistance_strength": 0.8,
        "holding_period": 5,
        "profit_target": 0.08
      },
      "risk_profile": {
        "volatility_tolerance": "low",
        "max_position_size": 0.18,
        "preferred_market_cap": "large_cap"
      },
      "performance_weights": {
        "return_weight": 0.3,
        "risk_weight": 0.4,
        "consistency_weight": 0.3
      }
    },
    "Opening_Gap": {
      "class": "OpeningGapStrategy",
      "module": "src.strategies.Opening_Gap",
      "priority": 5,
      "enabled": true,
      "market_conditions": ["gap_up", "gap_down"],
      "parameters": {
        "gap_threshold": 0.02,
        "volume_multiplier": 1.5,
        "fade_threshold": 0.5,
        "momentum_confirmation": true,
        "intraday_exit": true
      },
      "risk_profile": {
        "volatility_tolerance": "very_high",
        "max_position_size": 0.10,
        "preferred_market_cap": "all"
      },
      "performance_weights": {
        "return_weight": 0.7,
        "risk_weight": 0.1,
        "consistency_weight": 0.2
      }
    }
  },
  "market_condition_mapping": {
    "trending": {
      "description": "明確な上昇または下降トレンド",
      "indicators": ["price_trend", "volume_trend", "momentum"],
      "preferred_strategies": ["VWAP_Breakout", "GoldenCross", "Momentum"],
      "weight_adjustment": 1.1
    },
    "sideways": {
      "description": "横ばい・レンジ相場",
      "indicators": ["price_range", "support_resistance", "low_volatility"],
      "preferred_strategies": ["VWAP_Bounce"],
      "weight_adjustment": 1.0
    },
    "volatile": {
      "description": "高ボラティリティ相場",
      "indicators": ["high_volatility", "price_swings", "volume_spikes"],
      "preferred_strategies": ["VWAP_Breakout", "Opening_Gap"],
      "weight_adjustment": 1.2
    },
    "bullish": {
      "description": "強気相場",
      "indicators": ["positive_momentum", "rising_averages", "high_sentiment"],
      "preferred_strategies": ["GoldenCross", "Momentum"],
      "weight_adjustment": 1.05
    },
    "bearish": {
      "description": "弱気相場", 
      "indicators": ["negative_momentum", "falling_averages", "low_sentiment"],
      "preferred_strategies": [],
      "weight_adjustment": 0.8
    },
    "gap_up": {
      "description": "ギャップアップ",
      "indicators": ["opening_gap_positive", "volume_surge"],
      "preferred_strategies": ["Opening_Gap"],
      "weight_adjustment": 1.3
    },
    "gap_down": {
      "description": "ギャップダウン",
      "indicators": ["opening_gap_negative", "volume_surge"],
      "preferred_strategies": ["Opening_Gap"],
      "weight_adjustment": 1.3
    },
    "support_resistance": {
      "description": "サポート・レジスタンス明確",
      "indicators": ["clear_levels", "bounce_patterns"],
      "preferred_strategies": ["VWAP_Bounce"],
      "weight_adjustment": 1.1
    },
    "strong_volume": {
      "description": "出来高増加",
      "indicators": ["volume_spike", "participation"],
      "preferred_strategies": ["Momentum", "VWAP_Breakout"],
      "weight_adjustment": 1.15
    }
  },
  "integration_rules": {
    "symbol_level": {
      "description": "銘柄レベル（DSSMS主導）の判定ルール",
      "conditions": {
        "dssms_score_threshold": 0.6,
        "confidence_threshold": 0.6,
        "market_condition_weight": 0.2
      },
      "fallback_conditions": [
        "dssms_score < 0.6",
        "confidence < 0.6",
        "data_quality_poor"
      ]
    },
    "strategy_level": {
      "description": "戦略レベル（個別戦略主導）の判定ルール",
      "conditions": {
        "min_strategy_score": 0.5,
        "strategy_consensus_threshold": 0.7,
        "market_condition_alignment": 0.8
      },
      "selection_criteria": {
        "score_weight": 0.6,
        "market_fit_weight": 0.3,
        "risk_profile_weight": 0.1
      }
    },
    "hybrid_level": {
      "description": "ハイブリッドレベル（統合判定）のルール",
      "conditions": {
        "min_combined_score": 0.4,
        "score_difference_threshold": 0.2,
        "confidence_lower_bound": 0.3
      },
      "combination_methods": {
        "weighted_average": {
          "dssms_weight": 0.7,
          "strategy_weight": 0.3
        },
        "max_score_selection": true,
        "consensus_requirement": false
      }
    },
    "fallback_level": {
      "description": "フォールバックレベルのルール",
      "conditions": {
        "all_scores_low": true,
        "data_insufficient": true,
        "system_error": true
      },
      "fallback_actions": {
        "default_action": "hold",
        "emergency_exit": true,
        "risk_reduction": true
      }
    }
  },
  "performance_tracking": {
    "metrics": {
      "individual_strategy": [
        "total_return",
        "sharpe_ratio",
        "max_drawdown",
        "win_rate",
        "avg_holding_period"
      ],
      "integration_specific": [
        "dssms_contribution",
        "strategy_contribution", 
        "hybrid_efficiency",
        "switch_success_rate",
        "decision_accuracy"
      ],
      "risk_metrics": [
        "volatility",
        "var_95",
        "correlation_to_market",
        "tail_risk"
      ]
    },
    "benchmarks": {
      "market_index": "^N225",
      "strategy_indices": {
        "momentum": "momentum_index",
        "value": "value_index",
        "growth": "growth_index"
      }
    },
    "reporting_frequency": {
      "daily": ["portfolio_value", "positions", "trades"],
      "weekly": ["performance_metrics", "risk_metrics"],
      "monthly": ["comprehensive_report", "attribution_analysis"],
      "quarterly": ["strategy_review", "parameter_optimization"]
    }
  },
  "optimization": {
    "parameter_ranges": {
      "VWAP_Breakout": {
        "stop_loss": [0.02, 0.05],
        "take_profit": [0.10, 0.20],
        "volume_threshold": [1.1, 1.5]
      },
      "GoldenCross": {
        "short_window": [20, 80],
        "long_window": [100, 300]
      },
      "Momentum": {
        "lookback_period": [6, 24],
        "momentum_threshold": [0.03, 0.08]
      }
    },
    "optimization_methods": [
      "grid_search",
      "bayesian_optimization",
      "genetic_algorithm"
    ],
    "validation": {
      "cross_validation_folds": 5,
      "walk_forward_windows": 12,
      "out_of_sample_ratio": 0.3
    }
  },
  "metadata": {
    "version": "2.1.0",
    "created_date": "2025-01-28",
    "last_updated": "2025-01-28",
    "description": "DSSMS Phase 2 Task 2.1 戦略統合マッピング設定",
    "author": "DSSMS Integration Team",
    "compatibility": {
      "dssms_version": ">=5.0.0",
      "integration_manager_version": ">=2.1.0"
    },
    "change_log": [
      {
        "version": "2.1.0",
        "date": "2025-01-28", 
        "changes": [
          "初期実装: 5戦略の統合マッピング",
          "市場状況別の戦略選択ルール追加",
          "階層的判定システムの実装",
          "パフォーマンス追跡機能の追加"
        ]
      }
    ]
  }
}
