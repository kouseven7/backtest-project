{
  "execution_mode": {
    "deterministic": true,
    "random_seed": 42,
    "enable_reproducible_results": true
  },
  "randomness_control": {
    "scoring": {
      "enable_noise": true,
      "noise_level": 0.02
    },
    "ranking": {
      "enable_shuffling": false,
      "tie_breaking": "deterministic"
    },
    "switching": {
      "enable_probabilistic": true,
      "switching_probability": 0.9,
      "strict_threshold_mode": false
    },
    "comparison": {
      "enable_random_baseline": true,
      "random_seed": 42
    }
  },
  "performance_calculation": {
    "use_fixed_execution_price": false,
    "execution_delay_simulation": false,
    "slippage_simulation": false,
    "fixed_commission_rate": 0.001
  },
  "switch_criteria": {
    "perfect_order_breakdown_threshold": 0.7,
    "score_difference_threshold": 0.15,
    "minimum_holding_period_hours": 4,
    "confidence_threshold": 0.6
  },
  "risk_control": {
    "max_daily_switches": 3,
    "max_weekly_switches": 10,
    "drawdown_restriction_threshold": 0.05
  },
  "intelligent_switch_manager": {
    "unified_switching": true,
    "integration_coverage": 100,
    "quality_target": {
      "unnecessary_switch_rate": 0.2,
      "consistency_rate": 0.95,
      "integration_coverage_target": 100
    },
    "quality_tracking": {
      "enable_quality_tracking": true,
      "evaluation_period_days": 10,
      "min_evaluation_switches": 5,
      "enable_consistency_checking": true
    },
    "switching_criteria": {
      "daily_performance_threshold": 0.02,
      "weekly_performance_threshold": 0.05,
      "emergency_drawdown_limit": 0.1,
      "enable_emergency_switching": true
    },
    "decision_quality": {
      "enable_unnecessary_switch_detection": true,
      "unnecessary_switch_evaluation_days": 10,
      "unnecessary_switch_cost_rate": 0.002,
      "decision_consistency_window": 20
    }
  },
  "logging": {
    "detailed_switch_log": true,
    "score_calculation_log": true,
    "performance_breakdown_log": true,
    "log_level": "INFO"
  }
}
