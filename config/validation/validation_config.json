{
  "framework": {
    "validation_levels": ["basic", "unit", "integration", "performance", "production"],
    "parallel_execution": true,
    "early_termination": true,
    "auto_fix_attempts": 3,
    "timeout_seconds": 1800,
    "log_level": "INFO"
  },
  "dssms_specific": {
    "priority_components": [
      "hierarchical_ranking_system",
      "intelligent_switch_manager", 
      "market_condition_monitor",
      "dssms_scheduler",
      "dssms_backtester_v2"
    ],
    "critical_integrations": [
      "ranking_switch_integration",
      "switch_monitor_integration",
      "backtest_performance_integration",
      "data_diagnostics_integration",
      "scheduler_execution_integration"
    ]
  },
  "high_level_criteria": {
    "total_return_min": 0.10,
    "switch_success_rate_min": 0.80,
    "max_drawdown_max": 0.15,
    "sharpe_ratio_min": 1.5,
    "volatility_max": 0.25,
    "calmar_ratio_min": 1.0,
    "win_rate_min": 0.55,
    "profit_factor_min": 1.3
  },
  "test_data": {
    "use_fixed_benchmarks": true,
    "use_dynamic_generation": true,
    "cache_test_data": true,
    "data_retention_days": 30
  },
  "reporting": {
    "generate_html": true,
    "generate_json": true,
    "generate_excel": true,
    "auto_open_report": false,
    "include_charts": true
  },
  "auto_fix": {
    "enable_suggestions": true,
    "max_suggestions_per_issue": 3,
    "include_code_samples": true,
    "priority_threshold": "medium"
  }
}
