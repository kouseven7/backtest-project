{
  "_meta": {
    "version": "1.0",
    "created_date": "2025-09-25",
    "description": "DSSMS統合システム設定ファイル",
    "phase": "Phase 2 - Architecture Design"
  },
  "backtest_settings": {
    "initial_capital": 1000000,
    "switch_cost_rate": 0.001,
    "min_holding_days": 1,
    "max_switches_per_month": 10,
    "enable_dynamic_selection": true,
    "backtest_period": {
      "default_start_date": "2023-01-01",
      "default_end_date": "2023-12-31"
    }
  },
  "performance_targets": {
    "max_daily_execution_time_ms": 1000,
    "max_memory_usage_mb": 1024,
    "min_success_rate": 0.95,
    "max_switch_cost_per_month": 0.05,
    "target_sharpe_ratio": 1.5,
    "max_drawdown_threshold": 0.10
  },
  "data_management": {
    "cache_size_mb": 100,
    "cache_retention_days": 30,
    "data_fetch_timeout_sec": 30,
    "retry_attempts": 3,
    "enable_cache_compression": false,
    "cache_strategy": "LRU",
    "preload_popular_symbols": true,
    "popular_symbols": [
      "7203", "9984", "6758", "6861", "8306",
      "9434", "4502", "6501", "8316", "7267"
    ]
  },
  "strategy_adapter": {
    "enable_risk_management": true,
    "default_position_size": 1.0,
    "strategy_timeout_sec": 30,
    "enable_strategy_fallback": true,
    "fallback_strategy": "VWAPBreakoutStrategy",
    "data_quality_threshold": 0.8,
    "strategies": {
      "VWAPBreakoutStrategy": {
        "enabled": true,
        "priority": 1,
        "risk_weight": 0.15
      },
      "MomentumInvestingStrategy": {
        "enabled": true,
        "priority": 2,
        "risk_weight": 0.18
      },
      "BreakoutStrategy": {
        "enabled": true,
        "priority": 3,
        "risk_weight": 0.16
      },
      "VWAPBounceStrategy": {
        "enabled": true,
        "priority": 4,
        "risk_weight": 0.14
      },
      "OpeningGapStrategy": {
        "enabled": true,
        "priority": 5,
        "risk_weight": 0.12
      },
      "ContrarianStrategy": {
        "enabled": true,
        "priority": 6,
        "risk_weight": 0.13
      },
      "GCStrategy": {
        "enabled": true,
        "priority": 7,
        "risk_weight": 0.12
      }
    }
  },
  "switch_management": {
    "enable_switch_optimization": true,
    "cost_benefit_threshold": 0.005,
    "switch_cooldown_hours": 24,
    "max_consecutive_switches": 3,
    "enable_switch_momentum": false,
    "switch_decision_factors": {
      "dss_score_weight": 0.6,
      "cost_efficiency_weight": 0.2,
      "market_volatility_weight": 0.1,
      "portfolio_balance_weight": 0.1
    }
  },
  "position_management": {
    "max_positions_per_symbol": 5,
    "max_total_positions": 100,
    "enable_risk_limits": true,
    "max_portfolio_risk": 0.10,
    "position_sizing_method": "equal_weight",
    "enable_position_scaling": true,
    "scaling_factors": {
      "low_volatility": 1.2,
      "medium_volatility": 1.0,
      "high_volatility": 0.8
    },
    "risk_metrics": {
      "enable_var_calculation": true,
      "var_confidence_level": 0.95,
      "enable_stress_testing": false,
      "max_sector_concentration": 0.30
    }
  },
  "logging": {
    "log_level": "INFO",
    "enable_performance_logging": true,
    "enable_detailed_switch_logging": true,
    "enable_strategy_detail_logging": false,
    "enable_cache_logging": false,
    "log_file_rotation": {
      "max_size_mb": 50,
      "backup_count": 5
    },
    "log_destinations": {
      "console": true,
      "file": true,
      "database": false
    }
  },
  "risk_management": {
    "enable_position_limits": true,
    "enable_drawdown_protection": true,
    "drawdown_stop_loss": 0.15,
    "enable_volatility_adjustment": true,
    "volatility_lookback_days": 20,
    "risk_free_rate": 0.001,
    "correlation_threshold": 0.8,
    "enable_dynamic_hedging": false,
    "emergency_stop": {
      "enable": true,
      "max_daily_loss": 0.05,
      "max_weekly_loss": 0.10,
      "consecutive_loss_days": 5
    }
  },
  "market_data": {
    "primary_data_source": "yfinance",
    "enable_data_validation": true,
    "price_anomaly_threshold": 0.20,
    "volume_anomaly_threshold": 3.0,
    "enable_market_hours_check": true,
    "trading_hours": {
      "start_time": "09:00",
      "end_time": "15:00",
      "timezone": "Asia/Tokyo"
    },
    "holidays_calendar": "japan",
    "enable_after_hours_data": false
  },
  "optimization": {
    "enable_parameter_optimization": true,
    "optimization_frequency": "monthly",
    "optimization_lookback_days": 252,
    "min_data_points": 100,
    "optimization_methods": ["bayesian", "grid_search"],
    "enable_walk_forward_analysis": true,
    "validation_split": 0.2,
    "enable_ensemble_methods": false
  },
  "reporting": {
    "enable_daily_reports": true,
    "enable_weekly_reports": true,
    "enable_monthly_reports": true,
    "report_formats": ["excel", "pdf", "json"],
    "auto_export": {
      "enable": true,
      "export_path": "./output/dssms_results/",
      "filename_pattern": "dssms_backtest_{date}_{symbol}.{format}"
    },
    "performance_charts": {
      "enable": true,
      "chart_types": ["portfolio_value", "drawdown", "switches", "risk_metrics"],
      "chart_format": "png",
      "chart_resolution": "300dpi"
    }
  },
  "debugging": {
    "enable_debug_mode": false,
    "save_intermediate_results": false,
    "enable_profiling": false,
    "profiling_output_path": "./logs/profiling/",
    "enable_memory_monitoring": true,
    "memory_alert_threshold_mb": 2048,
    "enable_execution_tracing": false
  },
  "system": {
    "max_concurrent_processes": 4,
    "enable_multiprocessing": false,
    "process_timeout_sec": 300,
    "enable_graceful_shutdown": true,
    "shutdown_timeout_sec": 30,
    "system_health_check_interval_sec": 60,
    "enable_auto_recovery": true,
    "recovery_max_attempts": 3
  },
  "validation": {
    "enable_config_validation": true,
    "enable_data_validation": true,
    "enable_result_validation": true,
    "validation_rules": {
      "min_portfolio_value": 100000,
      "max_portfolio_value": 100000000,
      "min_switch_cost_rate": 0.0001,
      "max_switch_cost_rate": 0.01,
      "min_holding_days": 1,
      "max_holding_days": 30
    }
  }
}